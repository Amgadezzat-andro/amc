{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "afsakar/filament-otp-login": "^1.3",
        "awcodes/filament-curator": "^3.6",
        "bepsvpt/secure-headers": "^7.5",
        "bezhansalleh/filament-shield": "^3.2",
        "cactus-galaxy/filament-astrotomic": "@dev",
        "filament/filament": "^3.2",
        "guava/filament-icon-picker": "2.0",
        "guava/filament-nested-resources": "^1.2",
        "guzzlehttp/guzzle": "^7.9",
        "kenepa/translation-manager": "^4.0",
        "laravel/framework": "^10.10",
        "laravel/sanctum": "^3.3",
        "laravel/scout": "^10.11",
        "laravel/tinker": "^2.8",
        "mohamedsabil83/filament-forms-tinyeditor": "^2.3",
        "outerweb/filament-settings": "^1.2",
        "owen-it/laravel-auditing": "^13.6",
        "owenvoke/blade-fontawesome": "^2.6",
        "pepperfm/filament-json": "^1.1",
        "propaganistas/laravel-phone": "^5.3",
        "ralphjsmit/laravel-filament-seo": "^1.3",
        "ralphjsmit/laravel-seo": "^1.6",
        "solution-forest/filament-tree": "^2.0",
        "spatie/laravel-sitemap": "*",
        "stevebauman/location": "^7.5",
        "tapp/filament-auditing": "3.0"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.13",
        "fakerphp/faker": "^1.9.1",
        "laravel/pint": "^1.0",
        "laravel/sail": "^1.18",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^7.0",
        "phpunit/phpunit": "^10.1",
        "spatie/laravel-ignition": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
